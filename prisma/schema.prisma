generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Operador {
  id        Int      @id @default(autoincrement())
  nome      String
  login     String   @unique
  senha     String
  celular   String?
  status    String   @default("ATIVO")
  nivel     String   @default("OPERADOR")
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  atendimentos Atendimento[]
  logs         LogAuditoria[]
}

model Setor {
  id        Int      @id @default(autoincrement())
  descricao String
  status    String   @default("ATIVO")
  criadoEm  DateTime @default(now())
}

model Contato {
  id             Int      @id @default(autoincrement())
  nome           String
  telefone       String   @unique
  foto           String?
  criadoEm       DateTime @default(now())
  atendimentos   Atendimento[]
}

model Atendimento {
  id            Int      @id @default(autoincrement())
  protocolo     String   @unique
  status        String   @default("ESPERA")
  criadoEm      DateTime @default(now())
  finalizadoEm  DateTime?
  contato       Contato  @relation(fields: [contatoId], references: [id])
  contatoId     Int
  operador      Operador? @relation(fields: [operadorId], references: [id])
  operadorId    Int?
  mensagens     Mensagem[]
}

model Mensagem {
  id            Int      @id @default(autoincrement())
  remetente     String   
  conteudo      String   @db.Text
  tipo          String   @default("TEXTO")
  criadoEm      DateTime @default(now())
  atendimento   Atendimento @relation(fields: [atendimentoId], references: [id])
  atendimentoId Int
}

model SistemaConfig {
  id                Int      @id @default(1)
  waPhoneId         String?
  waWabaId          String?
  waToken           String?  @db.Text
  msgBoasVindas     String?  @db.Text
  msgFinalizacao    String?  @db.Text
  msgTransferencia  String?  @db.Text
  mostrarTransf     Boolean  @default(true)
  atualizadoEm      DateTime @updatedAt
}

model LogAuditoria {
  id               Int      @id @default(autoincrement())
  entidade         String   
  acao             String   
  detalhesAnterior String?  @db.Text
  detalhesNovo     String?  @db.Text
  ip               String?
  userAgent        String?
  timestamp        DateTime @default(now())
  operador         Operador? @relation(fields: [operadorId], references: [id])
  operadorId       Int?
}
